<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:OpsCenterSample.UI.Components"
    xmlns:team="using:OpsCenterSample.UI.Pages.Team"
    x:Class="OpsCenterSample.UI.Pages.Team.TeamPageView"
    x:DataType="team:TeamPageProjection"
    x:CompileBindings="True">
    <Grid RowDefinitions="Auto,Auto,*">
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Shift crew" FontSize="20" FontWeight="SemiBold"/>
            <Button Grid.Column="1" Margin="12,0,0,0" Content="Rotate on call" Command="{Binding RotateOnCallCommand}"/>
        </Grid>

        <ItemsControl Grid.Row="1" Margin="0,20,0,0" ItemsSource="{Binding Summary}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3"/>
            </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="components:MetricCardProjection">
                    <components:MetricCardView/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Grid.Row="2" Margin="0,20,0,0" Background="#F7F4EF" BorderBrush="#E6DED3" BorderThickness="1" CornerRadius="16" Padding="18">
            <ItemsControl ItemsSource="{Binding Members}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="team:TeamMemberProjection">
                        <Grid ColumnDefinitions="2*,*,Auto,Auto,Auto" Margin="0,0,0,12">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Focus}" Foreground="#6B6A67"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="{Binding Load}" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Margin="12,0,0,0" Padding="10,6" Background="#F0E7D8" CornerRadius="999">
                                <TextBlock Text="{Binding OnCall}" Foreground="#765739"/>
                            </Border>
                            <Button Grid.Column="3" Margin="12,0,0,0" Content="Ease" Command="{Binding EaseLoadCommand}"/>
                            <Button Grid.Column="4" Margin="12,0,0,0" Content="Assign" Command="{Binding AddLoadCommand}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</UserControl>
