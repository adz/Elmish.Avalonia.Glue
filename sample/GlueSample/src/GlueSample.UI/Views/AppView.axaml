<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:GlueSample.UI.ViewModels"
    x:Class="GlueSample.UI.Views.AppView"
    x:DataType="vm:CounterViewModel"
    x:CompileBindings="True"
    Title="Elmish.Avalonia.Glue Sample"
    Width="420" Height="520">
    <Grid Margin="24">
        <StackPanel Spacing="16">
            <TextBlock Text="Glue Sample" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding Count}" FontSize="48" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <Button Content="-" Width="44" Command="{Binding DecrementCommand}"/>
                <Button Content="Reset" Command="{Binding ResetCommand}"/>
                <Button Content="+" Width="44" Command="{Binding IncrementCommand}"/>
            </StackPanel>
            <Separator/>
            <TextBlock Text="Log" FontSize="13" FontWeight="SemiBold"/>
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Log}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:LogEntryViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,3">
                                <TextBlock Text="{Binding Time}"
                                           FontFamily="Monospace" FontSize="11"
                                           Foreground="{DynamicResource SystemBaseMediumColor}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Message}" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Window>
